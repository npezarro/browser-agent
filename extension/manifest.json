{
  "manifest_version": 3,
  "name": "Browser Agent Tab Manager",
  "version": "1.2.0",
  "description": "Companion extension for browser-agent. Provides background tab creation, tab queries, and focus management.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "debugger"
  ],
  "host_permissions": [
    "https://pezant.ca/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
